---
layout: null
---
[
  {% assign all = site.actualites | concat: site.idees | concat: site.passe | concat: site.spiritualite | concat: site.creations %}
  {% for item in all %}
    {
      "title": {{ item.title | jsonify }},
      "url": {{ item.url | jsonify }},
      "content": {{ item.content | strip_html | jsonify }}
    }{% unless forloop.last %},{% endunless %}
  {% endfor %}
]
